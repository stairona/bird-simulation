import numpy as np
import matplotlib.pyplot as plt

# -----------------------------
# Bird–Wind Turbine Risk Simulator (demo)
# Isabella County, MI: schematic (NOT real turbine locations)
# -----------------------------

rng = np.random.default_rng(42)

# --- World / geometry (normalized coordinate system) ---
W, H = 100.0, 100.0

# Two example migration corridors (centerline + width).
# You can tweak these to represent different "paths" through the county.
corridors = [
    {"name": "NW→SE corridor", "p0": np.array([10.0, 90.0]), "p1": np.array([90.0, 10.0]), "sigma": 10.0},
    {"name": "W→E corridor",   "p0": np.array([ 0.0, 55.0]), "p1": np.array([100.0, 55.0]), "sigma":  7.0},
]

def dist_point_to_segment(P, A, B):
    AB = B - A
    t = np.dot(P - A, AB) / (np.dot(AB, AB) + 1e-12)
    t = np.clip(t, 0.0, 1.0)
    proj = A + t * AB
    return np.linalg.norm(P - proj)

def corridor_density(P, corridors):
    # Mixture of Gaussians based on distance to each corridor centerline
    dvals = []
    for c in corridors:
        d = dist_point_to_segment(P, c["p0"], c["p1"])
        dvals.append(np.exp(-(d**2) / (2.0 * (c["sigma"]**2))))
    return float(np.sum(dvals))

# --- Turbines (synthetic demo layout) ---
N_TURBINES = 35
# Place more turbines near one corridor to demonstrate "path overlap" effects.
turbines = []
for i in range(N_TURBINES):
    if i < int(0.65 * N_TURBINES):
        # cluster near corridor 1
        t = rng.uniform(0.2, 0.8)
        base = corridors[0]["p0"] * (1 - t) + corridors[0]["p1"] * t
        jitter = rng.normal(0, 7, size=2)
        pos = np.clip(base + jitter, [0, 0], [W, H])
    else:
        pos = rng.uniform([0, 0], [W, H])
    turbines.append(pos)
turbines = np.array(turbines)

# --- Seasonal + migration parameters ---
# "migration_intensity" scales the number of migrants and risk.
# "night_fraction" affects risk (many migrants travel at night).
# "weather_risk" is an extra multiplier for poor visibility / storms.
SEASONS = [
    {"name": "Winter", "months": [12,1,2],  "migration_intensity": 0.20, "resident_fraction": 0.85, "night_fraction": 0.45, "weather_risk": 1.10},
    {"name": "Spring", "months": [3,4,5],   "migration_intensity": 1.00, "resident_fraction": 0.45, "night_fraction": 0.60, "weather_risk": 1.20},
    {"name": "Summer", "months": [6,7,8],   "migration_intensity": 0.25, "resident_fraction": 0.75, "night_fraction": 0.40, "weather_risk": 1.00},
    {"name": "Fall",   "months": [9,10,11], "migration_intensity": 0.90, "resident_fraction": 0.50, "night_fraction": 0.65, "weather_risk": 1.25},
]
month_to_season = {}
for s in SEASONS:
    for m in s["months"]:
        month_to_season[m] = s

# --- Simulation controls ---
DAYS = 365
START_MONTH = 1  # January
BIRDS_PER_DAY_BASE = 600        # baseline total birds/day (scaled by season)
MIGRANT_SPEED = 2.4             # units per step (higher = crosses map faster)
RESIDENT_SPEED = 1.2
STEPS_PER_DAY = 18              # finer steps => smoother motion

# Collision model knobs (tune these for demonstrations)
ROTOR_RADIUS = 2.2              # "risk radius" around turbine (normalized units)
BASE_STRIKE_PROB = 0.0025       # base per-step strike probability when inside risk radius
AVOIDANCE = 0.80                # 0.0=none, 0.9=strong avoidance
NIGHT_RISK_MULT = 1.5           # higher risk at night
ALTITUDE_MATCH_PROB = 0.55      # probability bird flies in rotor-swept zone (simplified)

# -----------------------------
# Bird generation
# -----------------------------
def sample_entry_exit_for_corridor(c):
    # spawn near p0 and move toward p1; add lateral noise
    p0, p1 = c["p0"], c["p1"]
    direction = p1 - p0
    direction = direction / (np.linalg.norm(direction) + 1e-12)

    # perpendicular for lateral spread
    perp = np.array([-direction[1], direction[0]])

    lateral = rng.normal(0, c["sigma"])
    start = p0 + perp * lateral + rng.normal(0, 1.5, size=2)
    end = p1 + perp * rng.normal(0, c["sigma"]) + rng.normal(0, 1.5, size=2)

    start = np.clip(start, [0,0], [W,H])
    end   = np.clip(end,   [0,0], [W,H])
    return start, end

def spawn_migrants(n, intensity):
    # pick corridors proportional to how "strong" they are (equal weight here)
    birds = []
    for _ in range(n):
        c = corridors[rng.integers(0, len(corridors))]
        start, end = sample_entry_exit_for_corridor(c)
        vec = end - start
        vec = vec / (np.linalg.norm(vec) + 1e-12)
        speed = MIGRANT_SPEED * rng.uniform(0.75, 1.25)
        birds.append({"pos": start, "vel": vec * speed, "type": "migrant"})
    return birds

def spawn_residents(n):
    birds = []
    for _ in range(n):
        pos = rng.uniform([0,0], [W,H])
        ang = rng.uniform(0, 2*np.pi)
        speed = RESIDENT_SPEED * rng.uniform(0.6, 1.4)
        vel = np.array([np.cos(ang), np.sin(ang)]) * speed
        birds.append({"pos": pos, "vel": vel, "type": "resident"})
    return birds

# -----------------------------
# Collision probability
# -----------------------------
def per_step_collision_prob(season, is_night, inside_risk):
    if not inside_risk:
        return 0.0
    p = BASE_STRIKE_PROB
    # season weather/visibility factor
    p *= season["weather_risk"]
    # more migrants at night => higher risk
    if is_night:
        p *= NIGHT_RISK_MULT
    # rotor-swept altitude chance
    p *= ALTITUDE_MATCH_PROB
    # avoidance reduces collisions
    p *= (1.0 - AVOIDANCE)
    return float(np.clip(p, 0.0, 0.25))

# -----------------------------
# Run simulation
# -----------------------------
def simulate():
    # day -> month approximation
    # Month lengths (non-leap year)
    month_lengths = {1:31,2:28,3:31,4:30,5:31,6:30,7:31,8:31,9:30,10:31,11:30,12:31}
    month = START_MONTH
    day_in_month = 1

    daily_deaths = np.zeros(DAYS, dtype=int)
    daily_birds = np.zeros(DAYS, dtype=int)

    # Turbine strike heatmap grid
    grid_n = 60
    heat = np.zeros((grid_n, grid_n), dtype=float)

    for day in range(DAYS):
        season = month_to_season[month]

        # Birds/day scales with season migration intensity
        birds_today = int(BIRDS_PER_DAY_BASE * (0.35 + 0.65 * season["migration_intensity"]) * rng.uniform(0.85, 1.15))
        daily_birds[day] = birds_today

        # Split into residents vs migrants by season
        n_res = int(birds_today * season["resident_fraction"])
        n_mig = birds_today - n_res

        birds = []
        birds.extend(spawn_residents(n_res))
        birds.extend(spawn_migrants(n_mig, season["migration_intensity"]))

        deaths = 0

        # Simulate movement over STEPS_PER_DAY
        for step in range(STEPS_PER_DAY):
            # decide if this step is "night" (simple)
            is_night = (rng.random() < season["night_fraction"])

            # Update each bird
            for b in birds:
                if b is None:
                    continue

                # move
                b["pos"] = b["pos"] + b["vel"]

                # reflect residents at borders; migrants leave the map and stop
                x, y = b["pos"]
                if b["type"] == "resident":
                    if x < 0 or x > W:
                        b["vel"][0] *= -1
                        b["pos"][0] = np.clip(b["pos"][0], 0, W)
                    if y < 0 or y > H:
                        b["vel"][1] *= -1
                        b["pos"][1] = np.clip(b["pos"][1], 0, H)
                else:
                    # migrants that exit are removed
                    if (x < -5) or (x > W + 5) or (y < -5) or (y > H + 5):
                        b_index = None  # marker
                        # remove by setting None
                        b["pos"] = None
                        b["vel"] = None
                        b["type"] = "gone"

                if b["pos"] is None:
                    continue

                # check nearby turbines (vectorized distance to all turbines)
                d = np.linalg.norm(turbines - b["pos"], axis=1)
                min_i = int(np.argmin(d))
                inside = (d[min_i] <= ROTOR_RADIUS)

                # collision draw
                p_col = per_step_collision_prob(season, is_night, inside)
                if rng.random() < p_col:
                    deaths += 1

                    # record heat location (near the turbine)
                    gx = int(np.clip((turbines[min_i,0] / W) * (grid_n - 1), 0, grid_n - 1))
                    gy = int(np.clip((turbines[min_i,1] / H) * (grid_n - 1), 0, grid_n - 1))
                    heat[grid_n - 1 - gy, gx] += 1.0

                    # bird removed
                    b["pos"] = None
                    b["vel"] = None
                    b["type"] = "dead"

        daily_deaths[day] = deaths

        # update month/day
        day_in_month += 1
        if day_in_month > month_lengths[month]:
            day_in_month = 1
            month += 1
            if month == 13:
                month = 1

    return daily_birds, daily_deaths, heat

birds, deaths, heat = simulate()

# -----------------------------
# Plot results
# -----------------------------
days = np.arange(1, DAYS + 1)
death_rate = deaths / np.maximum(birds, 1)

fig1 = plt.figure(figsize=(11, 6))
plt.plot(days, deaths, linewidth=1.2)
plt.title("Simulated Daily Bird Fatalities (Demonstration)")
plt.xlabel("Day of Year")
plt.ylabel("Deaths (count)")
plt.tight_layout()

fig2 = plt.figure(figsize=(11, 6))
plt.plot(days, death_rate, linewidth=1.2)
plt.title("Simulated Daily Fatality Rate (Deaths / Birds per Day)")
plt.xlabel("Day of Year")
plt.ylabel("Rate")
plt.tight_layout()

fig3 = plt.figure(figsize=(7, 6))
plt.imshow(heat, aspect="auto")
plt.title("Turbine Strike Hotspots (Synthetic Layout)")
plt.xlabel("X (west→east)")
plt.ylabel("Y (south→north)")
plt.tight_layout()

# Map view: turbines + corridors
fig4 = plt.figure(figsize=(7, 7))
plt.scatter(turbines[:,0], turbines[:,1], s=18)
for c in corridors:
    xs = [c["p0"][0], c["p1"][0]]
    ys = [c["p0"][1], c["p1"][1]]
    plt.plot(xs, ys, linewidth=2)
plt.xlim(0, W); plt.ylim(0, H)
plt.title("Synthetic Turbines + Migration Corridors (Demo Geometry)")
plt.xlabel("X"); plt.ylabel("Y")
plt.tight_layout()

plt.show()

# -----------------------------
# Quick seasonal summary (by month bins)
# -----------------------------
month_lengths = [31,28,31,30,31,30,31,31,30,31,30,31]
month_names = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]

month_deaths = []
month_birds = []
idx = 0
for ml in month_lengths:
    month_deaths.append(int(deaths[idx:idx+ml].sum()))
    month_birds.append(int(birds[idx:idx+ml].sum()))
    idx += ml

print("\nMonthly totals (demo):")
for m in range(12):
    rate = month_deaths[m] / max(month_birds[m], 1)
    print(f"{month_names[m]}: deaths={month_deaths[m]:5d}  birds={month_birds[m]:7d}  rate={rate:.5f}")

print("\nTuning tips:")
print("- Increase SEASONS Spring/Fall migration_intensity to show stronger peaks.")
print("- Increase AVOIDANCE to show how mitigation/behavior lowers collisions.")
print("- Move corridors or turbines to show how overlap drives hotspots.")
print("- Increase NIGHT_RISK_MULT and night_fraction to show night-migration effects.")
